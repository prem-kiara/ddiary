rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── User profiles & all subcollections ───────────────────────────────
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Diary entries — owner only
      match /entries/{entryId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Tasks — owner full control; assignee can read, update status, and comment.
      match /tasks/{taskId} {
        allow read: if request.auth != null
                   && (request.auth.uid == userId
                       || request.auth.uid == resource.data.assigneeUid
                       || request.auth.token.email == resource.data.assigneeEmail);
        allow create: if request.auth != null && request.auth.uid == userId;
        // Owner or assignee can update.
        allow update: if request.auth != null
                     && (request.auth.uid == userId
                         || request.auth.uid == resource.data.assigneeUid
                         || resource.data.assigneeEmail != null);
        allow delete: if request.auth != null && request.auth.uid == userId;

        // Comments — any authenticated user can read/create; only author can edit/delete
        match /comments/{commentId} {
          allow read, create:   if request.auth != null;
          allow update, delete: if request.auth != null
                                && request.auth.uid == resource.data.authorUid;
        }

        // Activity log — any authenticated user can read/create; never editable
        match /activity/{activityId} {
          allow read, create:   if request.auth != null;
          allow update, delete: if false;
        }
      }

      // Team members — owner only
      match /teamMembers/{memberId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Error logs — create-only
      match /errorLogs/{logId} {
        allow create: if request.auth != null && request.auth.uid == userId;
        allow read, update, delete: if false;
      }
    }

    // ─── Collection-group: lets assignees query their personal tasks ─────────
    // NOTE: update is intentionally omitted here — specific rules above handle it.
    match /{path=**}/tasks/{taskId} {
      allow read: if request.auth != null
                 && (resource.data.assigneeUid == request.auth.uid
                     || resource.data.assigneeEmail == request.auth.token.email);
    }

    // ─── User directory — lets the owner discover who has signed up ───────
    match /userDirectory/{uid} {
      allow create, update: if request.auth != null && request.auth.uid == uid;
      allow delete: if request.auth != null && request.auth.uid == uid;
      allow read: if request.auth != null;
    }

    // ─── In-app notifications (real-time, live) ──────────────────────────
    match /notifications/{notifId} {
      allow create: if request.auth != null
                   && (request.resource.data.senderEmail == request.auth.token.email
                       || request.resource.data.senderEmail == null
                       || !('senderEmail' in request.resource.data));
      allow read:   if request.auth != null
                   && resource.data.recipientEmail == request.auth.token.email;
      allow update: if request.auth != null
                   && resource.data.recipientEmail == request.auth.token.email;
      allow delete: if request.auth != null
                   && resource.data.recipientEmail == request.auth.token.email;
    }

    // ─── Anonymous error logs (pre-auth) ─────────────────────────────────
    match /errorLogs/{logId} {
      allow create: if request.auth != null;
      allow read, update, delete: if false;
    }

    // ─── Workspaces — shared Kanban boards ───────────────────────────────
    //
    // Access model:
    //   - Only members (or the creator) can read workspaces and tasks.
    //   - Any member can create/read/update tasks and comments.
    //   - Status updates are enforced by the UI (assignee only), not rules —
    //     keeping rules simple and reliable with UID-based member lookup.
    //   - Admin = workspace creator OR a member with role:'admin'.
    match /workspaces/{workspaceId} {
      function isWorkspaceMember() {
        return request.auth != null &&
          exists(/databases/$(database)/documents/workspaces/$(workspaceId)/members/$(request.auth.uid));
      }
      function isWorkspaceCreator() {
        return request.auth != null &&
          get(/databases/$(database)/documents/workspaces/$(workspaceId)).data.createdBy == request.auth.uid;
      }
      // Creator bypass guards against the common race where the workspace doc
      // exists but the member doc hasn't been written / replicated yet, and
      // against legacy workspaces that never got a member entry.
      function canAccessWorkspace() {
        return isWorkspaceMember() || isWorkspaceCreator();
      }

      // ── Workspace doc ────────────────────────────────────────────────────
      allow read:           if canAccessWorkspace()
                             || (request.auth != null && resource.data.createdBy == request.auth.uid);
      allow create:         if request.auth != null;
      allow update, delete: if canAccessWorkspace();

      // ── Members sub-collection ───────────────────────────────────────────
      // Read is open to authenticated users so useMyWorkspaces collection-group
      // query can fetch workspace docs after finding member entries.
      match /members/{uid} {
        allow read:           if request.auth != null;
        allow create, update: if request.auth != null;        // joining / invite acceptance
        allow delete:         if canAccessWorkspace()         // admin/creator removes others
                               || request.auth.uid == uid;   // member removes themselves (leave)
      }

      // ── Tasks sub-collection ─────────────────────────────────────────────
      // All members (or the workspace creator) can read ALL tasks in their
      // workspace. Any member can update a task — the UI restricts status
      // changes to the assignee. Keeps rules simple + resilient to races.
      match /tasks/{taskId} {
        allow read, create:   if canAccessWorkspace();
        allow update:         if canAccessWorkspace();
        allow delete:         if canAccessWorkspace()
                               && (resource.data.createdBy == request.auth.uid
                                   || isWorkspaceCreator());

        // Comments — workspace members/creator can read/create; only author can edit/delete
        match /comments/{commentId} {
          allow read, create:   if canAccessWorkspace();
          allow update, delete: if request.auth != null
                                && request.auth.uid == resource.data.authorUid;
        }

        // Activity log — members/creator can read/create; immutable once written
        match /activity/{activityId} {
          allow read, create:   if canAccessWorkspace();
          allow update, delete: if false;
        }
      }
    }

    // ─── Collection-group: lets users discover which workspaces they belong to
    match /{path=**}/members/{uid} {
      allow read: if request.auth != null;
    }

    // ─── Workspace leave requests ─────────────────────────────────────────────
    match /workspaceLeaveRequests/{reqId} {
      allow create: if request.auth != null
                   && request.resource.data.memberUid == request.auth.uid;
      allow read:   if request.auth != null
                   && (resource.data.memberUid    == request.auth.uid
                       || resource.data.ownerEmail == request.auth.token.email);
      allow update: if request.auth != null
                   && resource.data.ownerEmail == request.auth.token.email;
      allow delete: if request.auth != null
                   && (resource.data.memberUid    == request.auth.uid
                       || resource.data.ownerEmail == request.auth.token.email);
    }

    // ─── Workspace invites ────────────────────────────────────────────────────
    // read is open to all authenticated users because:
    //   a) invite doc ID is deterministic ({workspaceId}_{inviteeEmail}) — obscure enough
    //   b) getExistingInvite() reads docs that may NOT exist yet; accessing resource.data
    //      on a null resource causes a rules error → permission denied → invite breaks
    match /workspaceInvites/{inviteId} {
      allow create: if request.auth != null;
      allow read:   if request.auth != null;
      allow update: if request.auth != null
                   && resource.data.inviteeEmail == request.auth.token.email;
      allow delete: if request.auth != null
                   && resource.data.inviterUid == request.auth.uid;
    }

    // ─── Deny everything else ─────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
