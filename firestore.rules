rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── User profiles & all subcollections ───────────────────────────────
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Diary entries — owner only
      match /entries/{entryId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Tasks — owner full control; assignee can read & update status/fields.
      // We match on EITHER assigneeUid (linked) OR assigneeEmail (always set).
      match /tasks/{taskId} {
        allow read: if request.auth != null
                   && (request.auth.uid == userId
                       || request.auth.uid == resource.data.assigneeUid
                       || request.auth.token.email == resource.data.assigneeEmail);
        allow create: if request.auth != null && request.auth.uid == userId;
        allow update: if request.auth != null
                     && (request.auth.uid == userId
                         || ((request.auth.uid == resource.data.assigneeUid
                              || request.auth.token.email == resource.data.assigneeEmail)
                             && request.resource.data.ownerId     == resource.data.ownerId
                             && request.resource.data.assigneeEmail == resource.data.assigneeEmail));
        allow delete: if request.auth != null && request.auth.uid == userId;

        // Comments — owner & assignee (by uid or email) can read/create; author edits own
        match /comments/{commentId} {
          allow read, create: if request.auth != null
                             && (request.auth.uid == userId
                                 || request.auth.token.email == get(/databases/$(database)/documents/users/$(userId)/tasks/$(taskId)).data.assigneeEmail
                                 || request.auth.uid == get(/databases/$(database)/documents/users/$(userId)/tasks/$(taskId)).data.assigneeUid);
          allow update, delete: if request.auth != null
                                && request.auth.uid == resource.data.authorUid;
        }

        // Activity log — append-only; no edits or deletes ever
        match /activity/{activityId} {
          allow read, create: if request.auth != null
                             && (request.auth.uid == userId
                                 || request.auth.token.email == get(/databases/$(database)/documents/users/$(userId)/tasks/$(taskId)).data.assigneeEmail
                                 || request.auth.uid == get(/databases/$(database)/documents/users/$(userId)/tasks/$(taskId)).data.assigneeUid);
          allow update, delete: if false;
        }
      }

      // Team members — owner only
      match /teamMembers/{memberId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Error logs — create-only
      match /errorLogs/{logId} {
        allow create: if request.auth != null && request.auth.uid == userId;
        allow read, update, delete: if false;
      }
    }

    // ─── Collection-group: lets assignees query all their tasks ──────────
    // Supports lookup by UID or email so tasks are visible immediately.
    match /{path=**}/tasks/{taskId} {
      allow read: if request.auth != null
                 && (resource.data.assigneeUid == request.auth.uid
                     || resource.data.assigneeEmail == request.auth.token.email);
      allow update: if request.auth != null
                   && (resource.data.assigneeUid == request.auth.uid
                       || resource.data.assigneeEmail == request.auth.token.email)
                   && request.resource.data.ownerId       == resource.data.ownerId
                   && request.resource.data.assigneeEmail  == resource.data.assigneeEmail;
    }

    // ─── User directory — lets the owner discover who has signed up ───────
    match /userDirectory/{uid} {
      allow create, update: if request.auth != null && request.auth.uid == uid;
      allow delete: if request.auth != null && request.auth.uid == uid;
      allow read: if request.auth != null;
    }

    // ─── In-app notifications (real-time, live) ──────────────────────────
    match /notifications/{notifId} {
      allow create: if request.auth != null;
      allow read:   if request.auth != null
                   && resource.data.recipientEmail == request.auth.token.email;
      allow update: if request.auth != null
                   && resource.data.recipientEmail == request.auth.token.email;
      allow delete: if request.auth != null
                   && resource.data.recipientEmail == request.auth.token.email;
    }

    // ─── Anonymous error logs (pre-auth) ─────────────────────────────────
    match /errorLogs/{logId} {
      allow create: if request.auth != null;
      allow read, update, delete: if false;
    }

    // ─── Workspaces — shared Kanban boards ───────────────────────────────
    match /workspaces/{workspaceId} {
      function isWorkspaceMember() {
        return request.auth != null &&
          exists(/databases/$(database)/documents/workspaces/$(workspaceId)/members/$(request.auth.uid));
      }

      allow read:             if isWorkspaceMember();
      allow create:           if request.auth != null;
      allow update, delete:   if isWorkspaceMember();

      match /members/{uid} {
        allow read:           if isWorkspaceMember() || request.auth.uid == uid;
        allow create, update: if request.auth != null;
        allow delete:         if isWorkspaceMember();
      }

      match /tasks/{taskId} {
        allow read, write:    if isWorkspaceMember();

        match /comments/{commentId} {
          allow read, create: if isWorkspaceMember();
          allow update, delete: if request.auth != null && request.auth.uid == resource.data.authorUid;
        }

        match /activity/{activityId} {
          allow read, create: if isWorkspaceMember();
          allow update, delete: if false;
        }
      }
    }

    // ─── Collection-group: lets users discover which workspaces they belong to
    match /{path=**}/members/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
    }

    // ─── Deny everything else ─────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
